version: v2
clean: true
managed:
  enabled: true
  disable:
    - module: buf.build/googleapis/googleapis
    - module: buf.build/grpc-ecosystem/grpc-gateway
    - module: buf.build/prototools/protoc-gen-dal
  override:
    - file_option: go_package_prefix
      value: github.com/panyam/lucidcapture/gen/go
plugins:
  - remote: buf.build/protocolbuffers/go
    out: ../gen/go
    opt: paths=source_relative
    include_imports: true

  - local: protoc-gen-connect-go
    out: ../gen/go
    opt: paths=source_relative

  - local: protoc-gen-go-grpc
    out: ../gen/go
    opt: paths=source_relative,require_unimplemented_servers=false

  - local: protoc-gen-grpc-gateway
    out: ../gen/go
    opt: paths=source_relative

  # GORM DAL generator
  - local: protoc-gen-dal-gorm
    out: ../gen/gorm
    opt:
      - paths=source_relative
      - generate_dal=true
      - dal_filename_suffix=_dal
      - dal_output_dir=dal
      - entity_import_path=github.com/panyam/lucidcapture/gen/gorm

  # Datastore DAL generator
  - local: protoc-gen-dal-datastore
    out: ../gen/datastore
    opt:
      - paths=source_relative
      - generate_dal=true
      - dal_filename_suffix=_dal
      - dal_output_dir=dal
      - entity_import_path=github.com/panyam/lucidcapture/gen/datastore

  # TypeScript protobuf (for tsappkit frontend)
  - local: protoc-gen-es
    out: ../ts/gen
    include_imports: true
    opt: target=ts
